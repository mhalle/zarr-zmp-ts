{
  "name": "zarr-zmp",
  "version": "0.2.0",
  "description": "Read-only Zarr v3 store backed by ZMP manifest parquet files",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "hyparquet": "^1.7.0",
    "hyparquet-compressors": "^1.1.0",
    "fflate": "^0.8.0"
  },
  "peerDependencies": {
    "zarrita": ">=0.4.0"
  },
  "peerDependenciesMeta": {
    "zarrita": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "license": "Apache-2.0"
}
